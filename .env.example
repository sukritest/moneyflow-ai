# ---------------------------------------------------------------------------
# MoneyFlow AI - Environment Variables
# Copy this file to .env (local dev) and configure your deployment platform
# (Vercel, etc.) with the same variables for production.
# ---------------------------------------------------------------------------

# --- Database -----------------------------------------------------------
# Local dev default (SQLite, zero setup):
DATABASE_URL="file:./dev.db"
# Production (Supabase Postgres) - example:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"

# --- Supabase Auth -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# --- OAuth Providers (configured inside Supabase Dashboard) -------------
# Google OAuth - set up under Supabase > Authentication > Providers > Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LINE Login - Supabase doesn't ship a native LINE provider, so LINE is
# wired as a generic OAuth (OIDC) provider. See deployment guide.
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""

# --- OpenAI ---------------------------------------------------------------
# If left empty, all AI features fall back to deterministic mock responses
# so the app is fully usable without an API key.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MoneyFlow AI"

# --- Feature Flags (admin defaults, can be overridden in DB) -------------
NEXT_PUBLIC_ENABLE_FAMILY_WALLETS="true"
NEXT_PUBLIC_ENABLE_VOICE_INPUT="true"
NEXT_PUBLIC_ENABLE_OCR="true"
